<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <%=user.name%>
        <%= user.role%>
            <%=user.id%>

                <% if(user){ %>
                    <% if(user.role==="Admin" ){ %>
                        <h1>Admin Have All Rights Of this Application</h1>
                        <% } else if(user.role==="Editor" ){%>
                            <h1>Editor have to edit the app</h1>
                            <% }else{ %>
                                <h1>Viewers Don't have any rights</h1>
                                <% } %>
                                    <%} else {%>
                                        <h1>User Not Found.!!</h1>
                                        <% } %>
</body>

</html>