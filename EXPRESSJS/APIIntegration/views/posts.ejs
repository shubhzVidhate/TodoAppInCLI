<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>

<body>
    <h1>Posts from API</h1>

    <% if(data && data.length> 0){ %>
        <ul>
            <% data.forEach(d=>{ %>
                <li>
                    <h3>
                        <%= d.title %>
                    </h3>
                    <p>
                        <%= d.body %>
                    </p>
                </li>
                <% }) %>
        </ul>
        <% } else { %>
            <p>No Posts Available.!!</p>
            <% } %>
</body>

</html>